{
  "name": "whitney-site",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "export-data": "python3 scripts/export_catalog.py",
    "dev": "astro dev",
    "astro:build": "astro build",
    "pagefind": "pagefind --site dist --output-subdir _pagefind",
    "build": "npm run astro:build && npm run pagefind",
    "rebuild": "npm run export-data && npm run build",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "astro": "^6.4.6",
    "pagefind": "^1.5.2",
    "sharp": "^0.35.1"
  }
}
