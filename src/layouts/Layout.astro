---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "An independent visual explorer for the Whitney Museum of American Art's public collection. Built by Ryan Santos (frsantos.com).",
} = Astro.props;
const siteTitle = "The Whitney Visual Explorer";
const fullTitle = title === siteTitle
  ? title
  : `${title} — ${siteTitle}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="icon" href="data:," />

    <!-- No-FOUC theme bootstrap: read stored / system preference before paint. -->
    <script is:inline>
      (function () {
        try {
          const stored = localStorage.getItem("theme");
          const sys = window.matchMedia("(prefers-color-scheme: dark)").matches;
          const t = stored || (sys ? "dark" : "light");
          document.documentElement.dataset.theme = t;
        } catch (_) {
          document.documentElement.dataset.theme = "light";
        }
      })();
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600&display=swap"
    />
  </head>
  <body>
    <header class="site-header">
      <div class="site-header-inner">
        <a href="/" class="brand">The Whitney Visual Explorer</a>
        <nav>
          <a href="/saved">saved</a>
          <a href="/about">about</a>
          <button
            id="theme-toggle"
            type="button"
            class="theme-toggle"
            aria-label="Toggle light/dark mode"
            title="Toggle light/dark"
          >
            <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <circle cx="12" cy="12" r="4" />
              <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
            </svg>
            <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
            </svg>
          </button>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <!-- Image 404 fallback. ~5% of API-declared images 404; swap to a tile. -->
    <script is:inline>
      document.addEventListener("error", function (e) {
        const t = e.target;
        if (!(t instanceof HTMLImageElement)) return;
        if (t.closest("#results-grid .tile")) return;
        if (t.dataset.imgFallback === "applied") return;
        t.dataset.imgFallback = "applied";
        const ph = document.createElement("div");
        ph.className = "img-fallback";
        const label = t.getAttribute("alt") || "Image not available";
        ph.textContent = label.length > 60 ? label.slice(0, 60) + "…" : label;
        ph.title = label;
        t.replaceWith(ph);
      }, true);
    </script>

    <script is:inline>
      // Theme toggle.
      document.getElementById("theme-toggle")?.addEventListener("click", () => {
        const cur = document.documentElement.dataset.theme || "light";
        const next = cur === "light" ? "dark" : "light";
        document.documentElement.dataset.theme = next;
        try { localStorage.setItem("theme", next); } catch (_) {}
      });
    </script>

    <script is:inline>
      (function () {
        const key = "whitney:saved-artworks";

        function readSaved() {
          try {
            const parsed = JSON.parse(localStorage.getItem(key) || "[]");
            return Array.isArray(parsed) ? parsed.filter(Boolean).map(String) : [];
          } catch (_) {
            return [];
          }
        }

        function writeSaved(ids) {
          try {
            localStorage.setItem(key, JSON.stringify(ids));
          } catch (_) {}
          window.dispatchEvent(new CustomEvent("saved-artworks-change", { detail: { ids } }));
        }

        function isSaved(id) {
          return readSaved().includes(id);
        }

        function setSaved(id, shouldSave) {
          const ids = readSaved();
          const next = shouldSave
            ? [id, ...ids.filter((savedId) => savedId !== id)]
            : ids.filter((savedId) => savedId !== id);
          writeSaved(next);
          updateSaveButtons();
        }

        function updateSaveButtons(root) {
          const ids = new Set(readSaved());
          (root || document).querySelectorAll("[data-save-artwork]").forEach((button) => {
            const id = button.getAttribute("data-save-artwork");
            const saved = !!id && ids.has(id);
            button.classList.toggle("is-saved", saved);
            button.setAttribute("aria-pressed", saved ? "true" : "false");
            button.setAttribute("title", saved ? "Remove from saved" : "Save artwork");
          });
        }

        document.addEventListener("click", (event) => {
          if (!(event.target instanceof Element)) return;
          const button = event.target.closest("[data-save-artwork]");
          if (!button) return;
          event.preventDefault();
          event.stopPropagation();
          const id = button.getAttribute("data-save-artwork");
          if (!id) return;
          setSaved(id, !isSaved(id));
        });

        window.WhitneySaved = { read: readSaved, write: writeSaved, updateButtons: updateSaveButtons };
        updateSaveButtons();
        new MutationObserver((mutations) => {
          for (const mutation of mutations) {
            mutation.addedNodes.forEach((node) => {
              if (node instanceof Element) updateSaveButtons(node);
            });
          }
        }).observe(document.body, { childList: true, subtree: true });
      })();
    </script>

    <footer class="site-footer">
      <p>
        Data via the Whitney Museum's
        <a
          href="https://github.com/whitneymuseum/open-access"
          rel="noopener">open-access archive</a> (CC0) and
        <a href="https://whitney.org/about/website/api" rel="noopener">public API</a>.
        Images © respective rights holders, served from
        <code>whitneymedia.org</code>.
      </p>
      <p class="fine">
        Independent research project. Not affiliated with or endorsed by the
        Whitney Museum of American Art. Noncommercial, educational use only.
      </p>
    </footer>

    <style is:global>
      :root {
        --font-sans: "Geist", -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, sans-serif;
        --font-mono: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;

        --max-w: 1320px;
        --hero-max-w: 720px;

        /* Light theme (default) — pure monochrome, OKLCH-inspired. */
        --bg:        oklch(100%   0 0);          /* white */
        --bg-soft:   oklch(98.5%  0 0);          /* near-white card */
        --fg:        oklch(20.5%  0 0);          /* near-black text */
        --fg-muted:  oklch(45%    0 0);
        --fg-faint:  oklch(62%    0 0);
        --border:    oklch(92.2%  0 0);
        --border-strong: oklch(85% 0 0);
        --ring:      oklch(70% 0 0 / 0.4);
        --overlay:   color-mix(in oklab, oklch(100% 0 0) 85%, transparent);
      }
      [data-theme="dark"] {
        --bg:        oklch(14.5%  0 0);          /* near-black */
        --bg-soft:   oklch(20.5%  0 0);
        --fg:        oklch(98.5%  0 0);
        --fg-muted:  oklch(72%    0 0);
        --fg-faint:  oklch(55%    0 0);
        --border:    oklch(100%   0 0 / 0.1);
        --border-strong: oklch(100% 0 0 / 0.2);
        --ring:      oklch(80% 0 0 / 0.4);
        --overlay:   color-mix(in oklab, oklch(0% 0 0) 75%, transparent);
      }

      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }
      html { color-scheme: light dark; }
      [data-theme="dark"] { color-scheme: dark; }
      [data-theme="light"] { color-scheme: light; }

      body {
        font-family: var(--font-sans);
        background: var(--bg);
        color: var(--fg);
        line-height: 1.5;
        font-feature-settings: "ss01", "cv11";
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
        font-weight: 400;
      }
      a { color: inherit; text-decoration: none; }
      a:hover { text-decoration: underline; text-decoration-thickness: 1px; text-underline-offset: 3px; }
      img { max-width: 100%; height: auto; display: block; }
      code { font-family: var(--font-mono); font-size: 0.88em; }

      h1, h2, h3, h4 {
        font-family: var(--font-sans);
        font-weight: 300;
        margin: 0 0 0.5em 0;
        line-height: 1.1;
        letter-spacing: -0.01em;
      }
      h1 { font-size: clamp(2rem, 4vw, 3.25rem); font-weight: 300; }
      h2 { font-size: 1.65rem; }
      h3 { font-size: 1.2rem; }

      .site-header {
        position: sticky;
        top: 0;
        z-index: 50;
        background: color-mix(in oklab, var(--bg) 85%, transparent);
        backdrop-filter: saturate(180%) blur(12px);
        -webkit-backdrop-filter: saturate(180%) blur(12px);
        border-bottom: 1px solid var(--border);
      }
      .site-header-inner {
        max-width: var(--max-w);
        margin: 0 auto;
        padding: 0.85rem 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
      }
      .brand {
        font-family: var(--font-sans);
        font-weight: 500;
        font-size: 1.18rem;
        letter-spacing: 0.02em;
      }
      .brand:hover { text-decoration: none; opacity: 0.7; }
      .site-header nav {
        display: flex;
        align-items: center;
        gap: 1.25rem;
        font-size: 0.88rem;
      }
      .site-header nav a { color: var(--fg-muted); }
      .site-header nav a:hover { color: var(--fg); text-decoration: none; }

      .theme-toggle {
        background: none;
        border: 1px solid var(--border);
        border-radius: 999px;
        width: 36px;
        height: 36px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: var(--fg);
      }
      .theme-toggle:hover { border-color: var(--border-strong); }
      [data-theme="light"] .icon-moon { display: none; }
      [data-theme="dark"]  .icon-sun  { display: none; }

      main {
        max-width: var(--max-w);
        margin: 0 auto;
        padding: 1.5rem;
      }

      .site-footer {
        max-width: var(--max-w);
        margin: 5rem auto 0;
        padding: 1.5rem;
        border-top: 1px solid var(--border);
        font-size: 0.82rem;
        color: var(--fg-muted);
      }
      .site-footer p { margin: 0 0 0.5rem 0; max-width: 60ch; }
      .site-footer .fine { font-size: 0.76rem; color: var(--fg-faint); }
      .site-footer a { text-decoration: underline; text-decoration-color: color-mix(in oklab, currentColor 30%, transparent); }

      .img-fallback {
        width: 100%;
        min-height: 160px;
        background: var(--bg-soft);
        color: var(--fg-faint);
        font-size: 0.8rem;
        text-align: center;
        padding: 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1px solid var(--border);
      }

      .save-artwork-btn {
        border: 1px solid var(--border-strong);
        background: color-mix(in oklab, var(--bg) 86%, transparent);
        color: var(--fg-muted);
        border-radius: 999px;
        min-width: 36px;
        height: 36px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.45rem;
        font: inherit;
        font-size: 0.88rem;
        cursor: pointer;
        backdrop-filter: saturate(180%) blur(10px);
        -webkit-backdrop-filter: saturate(180%) blur(10px);
      }
      .save-artwork-btn svg {
        fill: none;
        stroke: currentColor;
        stroke-width: 1.8;
        pointer-events: none;
      }
      .save-artwork-btn:hover,
      .save-artwork-btn:focus-visible {
        color: var(--fg);
        border-color: var(--fg);
      }
      .save-artwork-btn.is-saved {
        color: var(--fg);
        background: var(--fg);
        border-color: var(--fg);
      }
      .save-artwork-btn.is-saved svg {
        color: var(--bg);
        fill: var(--bg);
      }
      .tile-save {
        position: absolute;
        top: 0.55rem;
        right: 0.55rem;
        z-index: 4;
        opacity: 0;
        transform: translateY(-4px);
        transition: opacity 0.18s ease, transform 0.18s ease;
      }
      .tile-shell:hover .tile-save,
      .tile:focus-visible + .tile-save,
      .tile-save:focus-visible,
      .tile-save.is-saved {
        opacity: 1;
        transform: translateY(0);
      }
      @media (hover: none) {
        .tile-save {
          opacity: 1;
          transform: none;
        }
      }

      /* Focus ring for accessibility. */
      :focus-visible {
        outline: 2px solid var(--ring);
        outline-offset: 2px;
      }
    </style>
  </body>
</html>
